{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:ci": {
      "dependsOn": ["^lint:ci"]
    },
    "test": {
      "dependsOn": ["^build", "^test"]
    },
    "test:react": {
      "dependsOn": ["^build"]
    },
    "test:vue": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build", "^type-check"]
    }
  }
}
