{
  "name": "component-inspector-example-consumer",
  "private": true,
  "type": "module",
  "description": "Example host and embedded consumer harness for the public Itera component inspector SDK.",
  "scripts": {
    "build": "vite build",
    "dev:embedded": "npm run dev:embedded:react",
    "dev:embedded:react": "vite --host 127.0.0.1 --port 4174 --open /embedded.html",
    "dev:embedded:vue": "vite --host 127.0.0.1 --port 4174 --open /embedded-vue.html",
    "dev:host": "vite --host 127.0.0.1 --port 4173 --open /host.html",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:react": "vitest run src/exampleConsumer.spec.ts",
    "test:vue": "vitest run src/vueExampleConsumer.spec.ts",
    "test:watch": "vitest watch",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@iteraai/inspector-protocol": "0.1.0",
    "@iteraai/react-component-inspector": "0.1.2",
    "@iteraai/vue-component-inspector": "0.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@stylistic/eslint-plugin-ts": "^4.2.0",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-unicorn": "^58.0.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.23.0",
    "vite": "^6.0.5",
    "vitest": "^3.0.8"
  }
}
