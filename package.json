{
  "name": "component-inspector",
  "private": true,
  "description": "Public monorepo for the Itera component inspector SDK packages.",
  "license": "MIT",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=22.13.0 <23",
    "npm": ">=10.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iteraai/component-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/iteraai/component-inspector/issues"
  },
  "homepage": "https://github.com/iteraai/component-inspector#readme",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:check": "node ./scripts/check-changeset-entry.mjs",
    "docs-drift:check": "npm run docs-drift:check --workspace @iteraai/react-component-inspector",
    "example:embedded": "npm run dev:embedded --workspace component-inspector-example-consumer",
    "example:host": "npm run dev:host --workspace component-inspector-example-consumer",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "release": "changeset publish",
    "test": "turbo run test",
    "test:examples": "npm run test --workspace component-inspector-example-consumer",
    "test:pack": "node ./scripts/validate-inspector-sdk-packages.mjs",
    "type-check": "turbo run type-check",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "turbo": "^2.4.0"
  }
}
