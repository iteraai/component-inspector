{
  "name": "@iteraai/vite-plugin-react-inspector",
  "version": "0.1.4",
  "license": "MIT",
  "type": "module",
  "description": "Vite plugin that injects the Itera React component inspector runtime into React-Vite apps.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iteraai/component-inspector.git",
    "directory": "packages/vite-plugin-react-inspector"
  },
  "bugs": {
    "url": "https://github.com/iteraai/component-inspector/issues"
  },
  "homepage": "https://github.com/iteraai/component-inspector/tree/main/packages/vite-plugin-react-inspector#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "prepack": "npm run build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@iteraai/inspector-protocol": "0.2.0",
    "@iteraai/react-component-inspector": "0.5.3"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@stylistic/eslint-plugin-ts": "^4.2.0",
    "@types/node": "^22.13.1",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-unicorn": "^58.0.0",
    "globals": "^15.14.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.23.0",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.8"
  }
}
